# =============================================================================
# last30days ADK Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# The agent needs a Google AI key to run. Source-backend keys are optional
# but unlock more search sources.
# =============================================================================

# ---------------------------------------------------------------------------
# Google AI — pick ONE approach
# ---------------------------------------------------------------------------

# Option A: Gemini API Key (simplest — get one at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# Option B: Vertex AI (production — uses Application Default Credentials)
# Run: gcloud auth application-default login
# Then uncomment these:
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_GENAI_USE_VERTEXAI=True

# Optional: override the Gemini model (default: gemini-2.5-flash)
# ADK_MODEL=gemini-2.5-pro

# ---------------------------------------------------------------------------
# Source backends (optional — each unlocks additional search sources)
# ---------------------------------------------------------------------------

# ScrapeCreators — unlocks Reddit, TikTok, Instagram, X search
# Get a key at https://scrapecreators.com
SCRAPECREATORS_API_KEY=

# OpenAI — fallback for Reddit search + model selection
OPENAI_API_KEY=

# xAI — X/Twitter search via Grok API
XAI_API_KEY=

# X/Twitter browser cookies — alternative X search via Bird CLI
# Extract from browser DevTools → Application → Cookies → x.com
AUTH_TOKEN=
CT0=

# Brave Search — web search backend
# Get a key at https://brave.com/search/api/
BRAVE_API_KEY=

# Parallel AI — web search backend
PARALLEL_API_KEY=

# OpenRouter — web search via Perplexity Sonar
OPENROUTER_API_KEY=

# Bluesky — AT Protocol search
BSKY_HANDLE=
BSKY_APP_PASSWORD=

# Truth Social — Mastodon API search
TRUTHSOCIAL_TOKEN=

# ---------------------------------------------------------------------------
# Observability (optional — for Cloud Run / production)
# ---------------------------------------------------------------------------

# GCS bucket for telemetry logs
# LOGS_BUCKET_NAME=

# BigQuery analytics (optional)
# BQ_ANALYTICS_DATASET_ID=
# BQ_ANALYTICS_GCS_BUCKET=
